{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex History Repair",
  "version": "0.1.0",
  "identifier": "com.alexlangl.codex-history-repair",
  "build": {
    "beforeDevCommand": "pnpm dev:web:ensure",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex History Repair",
        "width": 1060,
        "height": 780,
        "minWidth": 380,
        "minHeight": 540,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
